DISCORD_TOKEN=replace-with-your-bot-token
DISCORD_CHANNEL_ID=your-channel-id
DISCORD_GUILD_ID=your-server-id
RL_PLAYER_NAME=@YourInGameName
RL_PLAYER_PRIMARY_ID=Steam|76561197...|0

# Optional: comma-separated in-game names of friends/clanmates.
# They get a marker in the scoreboard and we surface their lifetime stats
# in the dashboard if they show up in your match history.
RL_FRIENDS=friend1,friend2

# --- Central server sync (optional) ---
# Upload each finished match to a central chumstats server (see deploy/server/).
# CHUMSTATS_REMOTE_URL=http://<server-host>:5050
# CHUMSTATS_API_KEY=<key from `chumstats admin create-user` on the server>
#
# Sync fidelity — two options:
#   summary (default, CHUMSTATS_SYNC_FULL_RAW=0)
#     Push stats + touches + goal/lifecycle events, but NOT the 30 Hz tick
#     firehose. Central DB stays small (~90 KB/match) and the dashboard is fast.
#   full (CHUMSTATS_SYNC_FULL_RAW=1)
#     ALSO push the raw tick firehose, so the central server holds a COMPLETE
#     raw archive you can re-derive any future stat from (or fix a bad
#     aggregation). Bigger DB + uploads (~10-30 MB/match). Use while your data
#     model is still in flux; switch back to summary once it's settled.
# CHUMSTATS_SYNC_FULL_RAW=0
