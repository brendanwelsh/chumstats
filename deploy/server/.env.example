# Chumstats central server config — copy to .env and edit.
# Lives on the server at $INSTALL_DIR/.env (default: ~/chumstats/.env).

# --- Server binding ---
# Bind to ALL interfaces. A VPN like Tailscale assigns the host its own IP on a
# separate interface, so a 127.0.0.1-only bind is NOT reachable over the VPN (or
# LAN). Uploads are key-authed; the read-only dashboard pages are not, so anyone
# who can reach the host (your LAN, your VPN, or a Cloudflare hostname) can read
# group stats — that's the intended friend-group model. Put it behind Cloudflare
# Access (or keep it VPN-only) if you want the public dashboard private.
CHUMSTATS_SERVER_HOST=0.0.0.0
CHUMSTATS_SERVER_PORT=5050

# --- Public URL ---
# Used when generating share links (Discord "view match", etc.), no trailing slash.
# LAN/VPN-only (works with no domain — use your server's hostname or IP):
CHUMSTATS_PUBLIC_URL=http://<server-host>:5050
# Public domain (once you wire up Cloudflare Tunnel):
# CHUMSTATS_PUBLIC_URL=https://stats.your-domain.com

# --- DB path ---
# Overridden by --db flag in the launchd plist (defaults to ~/chumstats/data/central.db).
# Leave this empty unless you want to override.
# CHUMSTATS_DB=

# --- Configured "self" for the central dashboard ---
# What the server's /dashboard page shows by default — usually the admin (you).
# Other players still see their own stats via /player/<their-name>.
RL_PLAYER_NAME=@YourName
RL_PLAYER_PRIMARY_ID=Steam|7656...|0

# --- Discord bot (optional) ---
# Run the match-post bot from the server instead of a client. Leave commented
# out to disable (e.g. if a client already posts).
# DISCORD_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=
# RL_FRIENDS=friend1,friend2,friend3
