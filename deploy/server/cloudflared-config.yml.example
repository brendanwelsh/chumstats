# Cloudflare Tunnel config for the chumstats central server.
# Path on macOS: ~/.cloudflared/config.yml
#
# Setup (one-time):
#   brew install cloudflared
#   cloudflared tunnel login                              # opens browser
#   cloudflared tunnel create chumstats                     # writes ~/.cloudflared/<uuid>.json
#   # add a CNAME for stats.your-domain.com -> <uuid>.cfargotunnel.com
#   cloudflared tunnel route dns chumstats stats.your-domain.com
#   cp deploy/server/cloudflared-config.yml.example ~/.cloudflared/config.yml
#   # edit the file, set `tunnel:` to the UUID from `cloudflared tunnel list`
#   cloudflared service install                           # autostart at boot
#
# Restrict /admin* and write endpoints to Tailscale (or Cloudflare Access).
# The chumstats server itself does NOT auth `/dashboard`, `/player/<name>`, etc.
# — anyone reaching the hostname can read stats. Match-summary upload is
# protected by X-Chumstats-Key; provisioning is CLI-only (no HTTP /admin route).

tunnel: REPLACE_WITH_TUNNEL_UUID
credentials-file: /Users/REPLACE_WITH_USERNAME/.cloudflared/REPLACE_WITH_TUNNEL_UUID.json

ingress:
  # Public read-only dashboard + match-summary upload endpoint.
  - hostname: stats.your-domain.com
    service: http://127.0.0.1:5050
    originRequest:
      noTLSVerify: true
      connectTimeout: 10s
      keepAliveConnections: 100

  # Catch-all (required by cloudflared).
  - service: http_status:404
