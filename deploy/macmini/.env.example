# Ballshark central server config — copy to .env and edit.
# This file lives on welsh-macmini at $INSTALL_DIR/.env (default: ~/ballshark/.env).

# --- Server binding ---
# Bind to loopback only; Cloudflare Tunnel + Tailscale reach the service.
# Direct LAN exposure is unnecessary and means anyone on your network can
# hit /admin without auth.
BALLSHARK_SERVER_HOST=127.0.0.1
BALLSHARK_SERVER_PORT=5050

# --- Public URL ---
# Used when generating share links (Discord "view match", etc.). Set this to
# the hostname Cloudflare Tunnel exposes (no trailing slash).
BALLSHARK_PUBLIC_URL=https://stats.your-domain.com

# --- DB path ---
# Overridden by --db flag in the launchd plist (defaults to ~/ballshark/data/central.db).
# Leave this empty unless you want to override.
# BALLSHARK_DB=

# --- Configured "self" for the central dashboard ---
# This is what the server's /dashboard page shows by default — usually the
# admin (you). Friends still see their own stats via /player/<their-name>.
RL_PLAYER_NAME=@ChumtheWaters
RL_PLAYER_PRIMARY_ID=Steam|76561197985273611|0

# --- Discord bot (optional) ---
# Same bot as your local install — moves from your Windows PC to here.
# Leave commented out to disable.
# DISCORD_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=
# RL_FRIENDS=Payanangeel,vexxl0l,twotoes7
