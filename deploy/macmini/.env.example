# Ballshark central server config — copy to .env and edit.
# This file lives on welsh-macmini at $INSTALL_DIR/.env (default: ~/ballshark/.env).

# --- Server binding ---
# Bind to ALL interfaces. Tailscale assigns the host a 100.x IP on its own
# interface, so a 127.0.0.1-only bind is NOT reachable over the tailnet (or LAN).
# Uploads are key-authed; the read-only dashboard pages are not, so anyone who
# can reach the host (your tailnet, your LAN, or a Cloudflare hostname) can read
# group stats — that's the intended friend-group model. Put it behind Cloudflare
# Access if you want the public dashboard private.
BALLSHARK_SERVER_HOST=0.0.0.0
BALLSHARK_SERVER_PORT=5050

# --- Public URL ---
# Used when generating share links (Discord "view match", etc.), no trailing slash.
# Tailnet-only (works today, no domain needed):
BALLSHARK_PUBLIC_URL=http://welsh-macmini:5050
# Public domain (once you wire up Cloudflare Tunnel):
# BALLSHARK_PUBLIC_URL=https://stats.ballshark.gg

# --- DB path ---
# Overridden by --db flag in the launchd plist (defaults to ~/ballshark/data/central.db).
# Leave this empty unless you want to override.
# BALLSHARK_DB=

# --- Configured "self" for the central dashboard ---
# This is what the server's /dashboard page shows by default — usually the
# admin (you). Friends still see their own stats via /player/<their-name>.
RL_PLAYER_NAME=@ChumtheWaters
RL_PLAYER_PRIMARY_ID=Steam|76561197985273611|0

# --- Discord bot (optional) ---
# Same bot as your local install — moves from your Windows PC to here.
# Leave commented out to disable.
# DISCORD_TOKEN=
# DISCORD_CHANNEL_ID=
# DISCORD_GUILD_ID=
# RL_FRIENDS=Payanangeel,vexxl0l,twotoes7
